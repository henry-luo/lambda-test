            "depth": 2,
            "elementIndex": 4,
            "children": [
              {
                "nodeType": "text",
                "text": "\nconst input = document.querySelector('input');\nconst optionOne = document.querySelector('.one');\nconst optionTwo = document.querySelector('.two');\nconst optionThree = document.querySelector('.three');\n\nfunction checkOptions(includedOptions, message) {\n  for (const option of document.querySelectorAll('option')) {\n    if (includedOptions.includes(option)) {\n      assert_false(\n        option.matches(':filtered'),\n        `${message}: option ${option.className} should not match :filtered.`);\n      assert_not_equals(\n        getComputedStyle(option).display,\n        'none',\n        `${message}: option ${option.className} should not be display:none.`);\n    } else {\n      assert_true(\n        option.matches(':filtered'),\n        `${message}: option ${option.className} should match :filtered.`);\n      assert_equals(\n        getComputedStyle(option).display,\n        'none',\n        `${message}: option ${option.className} should be display:none.`);\n    }\n  }\n}\n\nfunction pressKey(keyCode) {\n  return (new test_driver.Actions()\n    .keyDown(keyCode)\n    .keyUp(keyCode))\n    .send();\n}\n\npromise_test(async () => {\n  checkOptions([optionOne, optionTwo, optionThree],\n    'No options should be filtered out at the start of the test');\n\n  input.focus();\n  await pressKey('t');\n  checkOptions([optionTwo, optionThree],\n    'First option should be filtered out after typing \"t\"');\n\n  await pressKey('w');\n  checkOptions([optionTwo],\n    'Third option should be filtered out after typing \"tw\"');\n\n  await pressKey('z');\n  checkOptions([],\n    'All options should be filtered out after typing \"twz\"');\n\n  const backspace = '\\uE003';\n  await pressKey(backspace);\n  checkOptions([optionTwo],\n    'Second option should become unfiltered after pressing backspace.');\n\n  input.value = '';\n  checkOptions([optionOne, optionTwo, optionThree],\n    'No options should be filtered out after setting input.value to the empty string.');\n\n  input.value = 'tw';\n  checkOptions([optionTwo],\n    'Only option two should match when setting input.value to \"tw\".');\n}, 'Customizable combobox option:filtered behavior');\n\npromise_test(async () => {\n  input.value = '';\n  optionTwo.remove();\n  optionThree.remove();\n  checkOptions([optionOne],\n    'options should not be filtered out at the start of the test.');\n\n  function testCombination(one, two) {\n    if (typeof one === 'number') {\n      one = String.fromCodePoint(one);\n    }\n    if (typeof two === 'number') {\n      two = String.fromCodePoint(two);\n    }\n\n    optionOne.textContent = 'foo';\n    input.value = 'bar';\n    checkOptions([], `'bar' should not find 'foo'.`);\n\n    optionOne.textContent = two;\n    input.value = one;\n    checkOptions([optionOne], `'${one}' should find '${two}'`);\n\n    optionOne.textContent = one;\n    input.value = two;\n    checkOptions([optionOne], `'${two}' should find '${one}'`);\n  }\n\n  // u_strFoldCase from ICU is used to do case folding.\n  testCombination('a', 'A');\n  testCombination(0xe7, 0xc7); // ç Ç\n  testCombination(0xff, 0x178); // ÿ Ÿ\n  testCombination(0x188, 0x187); // ƈ Ƈ\n  testCombination(0xa727, 0xa726); // ꜧ Ꜧ\n  testCombination(0x10428, 0x10400); // 𐐨 𐐀\n}, 'Case folding');\n",
